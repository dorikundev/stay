<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h4>アカウント情報</h4>
          <%= link_to "編集", edit_user_registration_path, class: "btn btn-sm btn-outline-primary" %>
        </div>
        <div class="card-body">
          <!-- アカウント情報 -->
          <div class="account-info">
            <div class="mb-3">
              <strong>ユーザー名:</strong>
              <span class="ms-2"><%= current_user.username %></span>
            </div>
            <div class="mb-3">
              <strong>メールアドレス:</strong>
              <span class="ms-2"><%= current_user.email %></span>
            </div>
            <div class="mb-3">
              <strong>パスワード:</strong>
              <span class="ms-2">••••••••</span>
            </div>
            <div class="mb-3">
              <strong>最終更新日:</strong>
              <span class="ms-2"><%= current_user.updated_at.strftime("%Y/%m/%d") %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>