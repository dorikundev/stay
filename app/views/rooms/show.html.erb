<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-9">
      <div class="back-link mb-3">
        <%= link_to "← 戻る", request.referer.present? ? request.referer : rooms_path, class: "btn btn-outline-secondary" %>
      </div>
      <!-- 施設詳細 -->
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h4>施設詳細</h4>
          <% if user_signed_in? && current_user.id == @room.user_id %>
            <div>
              <%= link_to "編集", edit_room_path(@room), class: "btn btn-outline-primary me-2" %>
              <%= link_to "削除", room_path(@room), method: :delete,
                          data: { confirm: "このルームを削除すると、すべての予約情報も削除されます。本当に削除しますか？" },
                          class: "btn btn-outline-danger" %>
            </div>
          <% end %>
        </div>
        <div class="card-body p-4">
          <div class="row">
            <!-- 施設画像 -->
            <div class="col-md-6">
              <% if @room.image.attached? %>
                <%= image_tag @room.image.variant(resize_to_limit: [600, 400]), class: "img-fluid rounded" %>
              <% else %>
                <%= image_tag "default_room.png", class: "img-fluid rounded" %>
              <% end %>
            </div>
            <!-- 施設情報 -->
            <div class="col-md-6">
              <h4 class="mb-3"><%= @room.name %></h4>
              <div>
                <p>登録日: <%= @room.created_at.strftime("%Y/%m/%d") %></p>
                <p>住所: <%= @room.address %></p>
                <p>料金: <%= number_to_currency(@room.price) %>/日</p>
                <p><%= @room.description %></p>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- 予約フォーム -->
      <div class="card mt-4">
        <div class="card-header">
          <h4>予約</h4>
        </div>
        <div class="card-body p-4">
          <% if user_signed_in? %>
            <%= render 'reservations/form' %>
          <% else %>
              <p>予約するにはログインしてください</p>
              <%= link_to "ログイン", new_user_session_path, class: "btn btn-primary" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>