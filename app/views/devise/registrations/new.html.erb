<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h2 class="text-center mb-4">アカウント登録</h2>
          
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

            <div class="mb-3">
              <%= f.label :username, "ユーザー名", class: "form-label" %>
              <%= f.text_field :username, autofocus: true, autocomplete: "username", class: "form-control" %>
              <%= render "devise/shared/error_messages", resource: f.object, field: :username, help_text: '' %>
            </div>

            <div class="mb-3">
              <%= f.label :email, "メールアドレス", class: "form-label" %>
              <%= f.email_field :email, autocomplete: "email", class: "form-control" %>
              <%= render "devise/shared/error_messages", resource: f.object, field: :email, help_text: '' %>
            </div>

            <div class="mb-3">
              <%= f.label :password, "パスワード", class: "form-label" %>
              <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
              <%= render "devise/shared/error_messages", resource: f.object, field: :password, help_text: '' %>
            </div>

            <div class="mb-3">
              <%= f.label :password_confirmation, "パスワード確認", class: "form-label" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
              <%= render "devise/shared/error_messages", resource: f.object, field: :password_confirmation, help_text: '' %>
            </div>

            <div class="d-grid mt-4">
              <%= f.submit "登録", class: "btn btn-primary" %>
            </div>
          <% end %>
          
          <div class="mt-3 text-center">
            <%= render "devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>